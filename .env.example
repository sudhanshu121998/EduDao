# Environment Configuration Template
# Copy this file to .env and fill in your values

# ================================
# TESTNET CONFIGURATION
# ================================

# Sepolia Testnet RPC URL
# Get from: https://infura.io/ or https://alchemy.com/
# Example: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
SEPOLIA_RPC_URL=

# Private Key for Testnet Deployment
# WARNING: Never use your mainnet private key!
# Create a new wallet for testnet only
# Export from MetaMask: Account Details > Export Private Key
PRIVATE_KEY=

# Etherscan API Key (Optional - for contract verification)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ================================
# GAS REPORTER (Optional)
# ================================

# Enable gas reporting in tests
REPORT_GAS=false

# CoinMarketCap API Key (for USD gas estimates)
COINMARKETCAP_API_KEY=

# ================================
# BACKEND CONFIGURATION
# ================================

# Add your backend configuration here if needed
MONGODB_URI=
JWT_SECRET=
